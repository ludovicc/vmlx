{
  "name": "vmlx",
  "version": "1.1.4",
  "description": "The most complete MLX inference engine for Mac — voice, vision, Mamba, 5-layer caching, 20+ agentic tools",
  "main": "dist/main/index.mjs",
  "author": "ShieldStack LLC",
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://vmlx.net",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md}\"",
    "icons": "node generate-icons.js",
    "package": "electron-builder --dir",
    "dist": "electron-builder --mac",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "better-sqlite3": "^12.6.2",
    "dompurify": "^3.3.1",
    "highlight.js": "^11.11.1",
    "marked": "^12.0.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-ts": "^1.0.1",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron/notarize": "^3.1.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20.11.17",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "electron": "^28.2.3",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.0.0",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.2",
    "postcss": "^8.4.35",
    "prettier": "^3.2.5",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.0",
    "vitest": "^4.0.18"
  },
  "build": {
    "appId": "net.vmlx.app",
    "productName": "vMLX",
    "copyright": "Copyright 2026 ShieldStack LLC. All rights reserved.",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "resources/icon.png",
      "target": [
        "dmg",
        "zip"
      ],
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "notarize": {
        "teamId": "55KGF2S5AY"
      },
      "minimumSystemVersion": "26.0.0"
    },
    "dmg": {
      "background": "build/dmg-background.png",
      "window": {
        "width": 660,
        "height": 400
      },
      "iconSize": 80,
      "contents": [
        {
          "x": 200,
          "y": 220
        },
        {
          "x": 440,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "extraResources": [
      {
        "from": "bundled-python",
        "to": "bundled-python",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/*.pyc"
        ]
      },
      {
        "from": "../../../mlx/vllm-mlx/vmlx_engine",
        "to": "vmlx-engine-source/vmlx_engine",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/*.pyc"
        ]
      },
      {
        "from": "../../../mlx/vllm-mlx/pyproject.toml",
        "to": "vmlx-engine-source/pyproject.toml"
      }
    ],
    "files": [
      "dist/**/*",
      "out/**/*",
      "resources/**/*"
    ],
    "directories": {
      "buildResources": "resources",
      "output": "release"
    }
  }
}